PORT=3099
MOCK_DEPLOYS=false

# --- Local dev (recommended): use `railway login`, leave token commented out ---
RAILWAY_USE_CLI_LOGIN=true
# RAILWAY_API_TOKEN=

# --- Production (API on Railway/CI): account token from railway.com/account/tokens ---
# Create an ACCOUNT token (not a project token). Leave workspace blank for account scope.
# RAILWAY_USE_CLI_LOGIN=false
# RAILWAY_API_TOKEN=

# All user deploys go into this one Railway project (one service per deploy)
RAILWAY_PROJECT=pooshit
RAILWAY_ENVIRONMENT=production

# Optional — only needed if you have multiple distinct workspaces
# RAILWAY_WORKSPACE=ac292b3f-9cd8-4fd5-b68b-1141e21232fd

# Leave unset to use Railway *.up.railway.app URLs (no custom domain needed)
# POOSHIT_DOMAIN=yourdomain.com

# Comma-separated origins for CORS (default *). Example for production:
# ALLOWED_ORIGINS=https://your-landing.pages.dev

# Production Postgres (Railway plugin). Omit for local SQLite (file:./pooshit.db)
# DATABASE_URL=postgresql://user:pass@host:5432/pooshit

FREE_TTL_HOURS=24
FREE_MAX_BYTES=52428800

# CLI default (local dev)
POOSHIT_API_URL=http://localhost:3099
