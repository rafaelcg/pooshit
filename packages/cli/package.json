{
  "name": "pooshit",
  "version": "0.1.4",
  "description": "Deploy from your terminal in ~60 seconds. One command, public URL on *.pooshit.dev.",
  "homepage": "https://pooshit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelcg/pooshit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/rafaelcg/pooshit/issues"
  },
  "type": "module",
  "bin": {
    "pooshit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hosting",
    "deploy",
    "cli",
    "terminal",
    "pooshit",
    "static-site",
    "zero-config"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^13.1.0",
    "ignore": "^7.0.4",
    "open": "^10.1.2",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
