{
  "name": "pooshit",
  "version": "0.1.2",
  "description": "Ship anything with one command. Zero config.",
  "type": "module",
  "bin": {
    "pooshit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
