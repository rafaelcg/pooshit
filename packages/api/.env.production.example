# Pooshit API — production env (Railway `pooshit-api` project)
# Do not commit real tokens. Set these in Railway dashboard or via CLI.

NODE_ENV=production
MOCK_DEPLOYS=false
RAILWAY_USE_CLI_LOGIN=false

# Account token from https://railway.com/account/tokens (NOT a project token)
RAILWAY_API_TOKEN=

# Shared Railway project where user deploys land (one service per deploy)
RAILWAY_PROJECT=pooshit
RAILWAY_ENVIRONMENT=production

# Injected automatically when Postgres plugin is linked to the API service
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Ephemeral upload scratch space in the container
UPLOADS_DIR=/tmp/pooshit-uploads

FREE_TTL_HOURS=24
FREE_MAX_BYTES=52428800

# Optional — comma-separated origins once landing is on Pages
# ALLOWED_ORIGINS=https://pooshit.dev,https://pooshit.pages.dev

# Optional — custom subdomain base for user deploys (requires deploy-proxy Worker on *.domain)
POOSHIT_DOMAIN=pooshit.dev

# --- Hetzner static hosting (Option A hybrid) ---
# Static sites (index.html, no package.json) upload via SSH to a CPX22 VPS.
# See infra/hetzner/README.md for VPS + DNS setup.

# HETZNER_STATIC_ENABLED=true
# HETZNER_SSH_HOST=123.45.67.89
# HETZNER_SSH_PORT=22
# HETZNER_SSH_USER=root
# HETZNER_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...
# HETZNER_STATIC_DOMAIN=static.yourdomain.com
# HETZNER_SITES_ROOT=/var/www/pooshit/sites
