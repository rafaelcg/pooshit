{
  "name": "@pooshit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./src/instrument.ts' tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@sentry/hono": "^10.53.1",
    "@sentry/node": "^10.53.1",
    "better-sqlite3": "^11.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.43.1",
    "execa": "^9.5.2",
    "hono": "^4.7.7",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.7",
    "ssh2": "^1.16.0",
    "tar": "^7.4.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/ssh2": "^1.15.5",
    "@types/tar": "^6.1.13",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
