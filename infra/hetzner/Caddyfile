# Wildcard static hosting for Pooshit (Option A hybrid)
#
# DNS: *.static.yourdomain.com → CPX22 public IP
# TLS: Caddy obtains certs automatically via Let's Encrypt

{
	email you@example.com
}

*.static.yourdomain.com {
	root * /var/www/pooshit/sites/{labels.2}
	file_server
	try_files {path} /index.html

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
